    df_mig = pd.DataFrame(migration_data, columns=['CN', 'MCI', 'AD'], index=['Baseline', 'Year 1', 'Year 2', 'Year 3'])
    sns.heatmap(df_mig.T, annot=True, fmt='d', cmap='YlOrBr', ax=ax4)
    ax4.set_title("4. Longitudinal Patient State Migration (Heatmap)", fontsize=14, fontweight='bold')

