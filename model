# ==================== 1️⃣ DEEP MODELS ====================

class BiLSTM_Researcher(nn.Module):
    """Bi-LSTM مع Attention و LayerNorm"""
    def __init__(self, input_dim, hidden=256, classes=3):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden, batch_first=True, bidirectional=True, num_layers=2, dropout=0.3)
        self.ln = nn.LayerNorm(hidden*2)
        self.attn = nn.Linear(hidden*2,1)
        self.fc = nn.Sequential(nn.Linear(hidden*2,128), nn.ReLU(), nn.Linear(128,classes))
        
    def forward(self, x):
        o,_ = self.lstm(x)
        o = self.ln(o)
        w = torch.softmax(self.attn(o), dim=1)
        c = torch.sum(w*o, dim=1)
        return self.fc(c), w

class DeepGAT_Researcher(nn.Module):
    """Deep GATv2 مع GlobalAttention"""
    def __init__(self, feat, hidden=128, classes=3, heads=16):
        super().__init__()
        self.conv1 = GATv2Conv(feat, hidden, heads=heads, dropout=0.2)
        self.bn1 = GeoBatchNorm(hidden*heads)
        self.conv2 = GATv2Conv(hidden*heads, hidden, heads=heads, dropout=0.2)
        self.bn2 = GeoBatchNorm(hidden*heads)
        self.pool = GlobalAttention(nn.Sequential(nn.Linear(hidden*heads,1), nn.Sigmoid()))
        self.fc = nn.Sequential(nn.Linear(hidden*heads,64), nn.ReLU(), nn.Linear(64,classes))
        
    def forward(self,x,edge_index,batch=None):
        x = F.elu(self.bn1(self.conv1(x, edge_index)))
        x = F.elu(self.bn2(self.conv2(x, edge_index)))
        return self.fc(self.pool(x,batch))

class TripleResMeta(nn.Module):
    """Meta-Ensemble Triple Residual"""
    def __init__(self, input_dim=9, classes=3):
        super().__init__()
        self.input_layer = nn.Linear(input_dim,512)
        self.res1 = nn.Sequential(nn.Linear(512,512), nn.BatchNorm1d(512), nn.ReLU(), nn.Dropout(0.3))
        self.res2 = nn.Sequential(nn.Linear(512,512), nn.BatchNorm1d(512), nn.ReLU(), nn.Dropout(0.3))
        self.res3 = nn.Sequential(nn.Linear(512,512), nn.BatchNorm1d(512), nn.ReLU(), nn.Dropout(0.3))
        self.out = nn.Linear(512,classes)
        
    def forward(self,x):
        x = F.relu(self.input_layer(x))
        x = self.res1(x)+x
        x = self.res2(x)+x
        x = self.res3(x)+x
        return self.out(x)

# ==================== 2️⃣ DATA PREPARATION ====================

def prepare_sequences(df, features, target, seq_len=19):
    seqs, labels, statics, graphs = [], [], [], []
    dti_cols = [c for c in features if "DTIROI" in c]
    for rid in df["RID"].unique():
        p = df[df["RID"]==rid].sort_values("Years_bl")
        if p[target].isnull().all(): continue
        x_raw = p[features].values
        y_val = int(p[target].dropna().iloc[-1])
        
        # Padding للوصول لأقصى seq_len
        if len(x_raw) < seq_len:
            x_pad = np.vstack([np.zeros((seq_len - len(x_raw), x_raw.shape[1])), x_raw])
        else:
            x_pad = x_raw[-seq_len:]  # آخر 19 زيارة فقط
        
        # بناء الرسم البياني من بيانات DTI
        dti_data = x_raw[-1,:len(dti_cols)]
        corr = np.corrcoef(dti_data.reshape(-1,1))
        edge_index = torch.tensor(np.argwhere(np.abs(corr)>0.5).T, dtype=torch.long)
        graphs.append(Data(x=torch.tensor(dti_data).view(-1,1).float(), edge_index=edge_index))
        
        seqs.append(x_pad)
        labels.append(y_val)
        statics.append(x_raw[-1])
    return np.array(seqs), np.array(labels), np.array(statics), graphs

# ==================== 3️⃣ STOCHASTIC SIMULATION ====================

def realistic_simulation(Y_core):
    n = len(Y_core)
    sim_results = []
    for year in [1,2,3]:
        preds = []
        for i in range(n):
            current = Y_core[i]
            rand_val = np.random.rand()
            if current==0 and rand_val < 0.10*year:
                new_state = 1
            elif current==1 and rand_val < 0.20*year:
                new_state = 2
            else:
                new_state = current
            # هامش خطأ 5%
            if np.random.rand()<0.05:
                new_state = np.random.choice([0,1,2])
            preds.append(new_state)
        sim_results.append(np.array(preds))
    return sim_results

