# ==================== 1️⃣ RESEARCH-GRADE ARCHITECTURES ====================

class BiLSTM_Researcher(nn.Module):
    def __init__(self, input_dim, hidden=256, classes=3):
        super().__init__()
        self.lstm = nn.LSTM(input_dim, hidden, batch_first=True, bidirectional=True, num_layers=2)
        self.attn = nn.Linear(hidden*2, 1)
        self.fc = nn.Linear(hidden*2, classes)
    def forward(self, x):
        o, _ = self.lstm(x)
        w = torch.softmax(self.attn(o), dim=1)
        return self.fc(torch.sum(w*o, dim=1)), w

class DeepGAT_Researcher(nn.Module):
    def __init__(self, feat, hidden=128, classes=3):
        super().__init__()
        self.conv1 = GATv2Conv(feat, hidden, heads=8)
        self.bn1 = GeoBatchNorm(hidden*8)
        self.pool = GlobalAttention(nn.Sequential(nn.Linear(hidden*8, 1), nn.Sigmoid()))
        self.fc = nn.Linear(hidden*8, classes)
    def forward(self, x, edge_index, batch=None):
        x = F.elu(self.bn1(self.conv1(x, edge_index)))
        return self.fc(self.pool(x, batch))



# ==================== 2️⃣ CORE ENGINE UTILS ====================

def prepare_sequences(df, features, target, seq_len=19):
    seqs, labels, graphs = [], [], []
    dti_cols = [c for c in features if "DTIROI" in c]
    for rid in df["RID"].unique():
        p = df[df["RID"]==rid].sort_values("Years_bl")
        if p[target].isnull().all(): continue
        x_raw = p[features].values
        x_pad = np.vstack([np.zeros((seq_len - len(x_raw), x_raw.shape[1])), x_raw]) if len(x_raw)<seq_len else x_raw[-seq_len:]
        dti_data = x_raw[-1, :len(dti_cols)]
        edge_index = torch.tensor(np.argwhere(np.abs(np.corrcoef(dti_data.reshape(-1,1)))>0.5).T, dtype=torch.long)
        graphs.append(Data(x=torch.tensor(dti_data).view(-1,1).float(), edge_index=edge_index))
        seqs.append(x_pad); labels.append(int(p[target].dropna().iloc[-1]))
    return np.array(seqs), np.array(labels), graphs

def simulate_prognosis(Y_core, acc_list):
    """Simulates future states and individual model predictions for visualization"""
    future_paths = []
    for year in [1, 2, 3]:
        # Logic: Some MCI move to AD, Some CN move to MCI
        path = [np.clip(y + (1 if np.random.rand() < 0.12*year else 0), 0, 2) for y in Y_core]
        future_paths.append(np.array(path))
    return future_paths

