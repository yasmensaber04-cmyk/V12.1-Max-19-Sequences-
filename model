    ax3.set_title("3. Prognostic Accuracy Decay", fontsize=14, fontweight='bold')
    ax3.set_ylim(70, 105)

    # 4. Patient Migration Heatmap (Transition Trends)
    ax4 = plt.subplot2grid((3, 3), (1, 0), colspan=2)
